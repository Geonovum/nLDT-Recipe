  "variables": {
    "magicNumber": 42,
    "magicLink": {
      "rel": "process",
      "title": "multiply",
      "type": "application/process+json",
      "href": "http://localhost:8080/geonovum/v1/processes/multiply"
    }
  },
  "processing": [
    {
      "id": "processing1",
      "title": "blabla",
      "description": "blabla",

      "nodes": [
        {
          "id": "step1",
          "link": {
            "rel": "process",
            "title": "add",
            "type": "application/process+json",
            "href": "http://localhost:8080/geonovum/v1/processes/add"
          },
          "body": {
            "inputs": {
              "number1": 19,
              "number2": 7
            },
            "outputs": {
              "sum": {
                "transmissionMode": ["value"]
              }
            }
          }
        },
        {
          "id": "step2a",
          "link": "$magicLink",
          "body": {
            "inputs": {
              "number1": ":step1.outputs.sum",
              "number2": 5
            },
            "outputs": {
              "product": {
                "transmissionMode": ["value"]
              }
            }
          }
        },
        {
          "id": "step2b",
          "link": {
            "rel": "process",
            "title": "multiply",
            "type": "application/process+json",
            "href": "http://localhost:8080/geonovum/v1/processes/multiply"
          },
          "execution": {
            "mode": "async"
          },
          "body": {
            "inputs": {
              "number1": ":step1.outputs.sum",
              "number2": 6
            },
            "outputs": {
              "product": {
                "transmissionMode": ["value"]
              }
            },
            "subscriber": {
              "successUri": "http://localhost:8081/oven/v1/callback/:jobId?type=success",
              "inProgressUri": "http://localhost:8081/oven/v1/callback/:jobId?type=inProgress",
              "failedUri": "http://localhost:8081/oven/v1/callback/:jobId?type=failed"
            }
          }
        },
        {
          "id": "step3",
          "link": {
            "rel": "process",
            "title": "multiply",
            "type": "application/process+json",
            "href": "http://localhost:8080/geonovum/v1/processes/multiply"
          },
          "body": {
            "inputs": {
              "number1": ":step2b.outputs.product",
              "number2": "$magicNumber"
            },
            "outputs": {
              "product": {
                "transmissionMode": ["value"]
              }
            }
          }
        }
      ],

      "subscriber": {
        "successUri": ":serviceUrl/callback/:recipeId?type=success",
        "inProgressUri": ":serviceUrl/callback/:recipeId?type=inProgress",
        "failedUri": ":serviceUrl/callback/:recipeId?type=failed"
