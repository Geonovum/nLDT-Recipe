meta {
  name: Post recipe ref
  type: http
  seq: 3
}

post {
  url: {{serviceHost}}/executeref
  body: json
  auth: inherit
}

body:json {
  {
    "type": "recipe-ref",
    "recipe": "http://oup:8081/geonovum/v1/recipes/calculate.json",
    "variables": {
      "magicNumber": 71,
      "magicLink": {
              "rel": "process",
              "title": "multiply",
              "type": "application/process+json",
              "href": "http://nens:8080/geonovum/v1/processes/multiply"
            }
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
